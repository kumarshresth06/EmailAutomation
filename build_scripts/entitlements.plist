<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
   entitlements.plist — macOS Hardened Runtime entitlements
   Used by codesign in build_scripts/build_macos.sh
-->
<plist version="1.0">
<dict>
    <!-- Allow JIT compilation (needed by some Python extensions) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned executable memory (PyInstaller bootloader needs this) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Disable Library Validation so bundled .dylib files load correctly -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network: outbound (SMTP, web scraping) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- File access: user-selected files (CSV / Excel via dialog) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Downloads folder read-write (common save location) -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
